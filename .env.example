# ============================================================================
# AI-AA LMS — Environment Variables
# Copy this file to .env and modify values accordingly
# DO NOT commit .env to version control
# ============================================================================

# ---- General ----
COMPOSE_PROJECT_NAME=ai-aa-lms
ENVIRONMENT=development
TZ=Asia/Jakarta

# ---- PostgreSQL ----
POSTGRES_DB=moodle
POSTGRES_USER=moodle
POSTGRES_PASSWORD=moodle_secret_change_me
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=100

# ---- Moodle ----
MOODLE_DATABASE_HOST=postgres
MOODLE_DATABASE_PORT_NUMBER=5432
MOODLE_DATABASE_NAME=moodle
MOODLE_DATABASE_USER=moodle
MOODLE_DATABASE_PASSWORD=moodle_secret_change_me
MOODLE_USERNAME=admin
MOODLE_PASSWORD=Admin@12345
MOODLE_EMAIL=admin@lms.com
MOODLE_SITE_NAME=AI Academic Assistant LMS
MOODLE_LANG=en
MOODLE_SKIP_BOOTSTRAP=no
MOODLE_SMTP_HOST=
MOODLE_SMTP_PORT=
MOODLE_SMTP_USER=
MOODLE_SMTP_PASSWORD=

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_change_me

# ---- Nginx ----
NGINX_SERVER_NAME=localhost
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---- pgAdmin ----
PGADMIN_DEFAULT_EMAIL=admin@lms.com
PGADMIN_DEFAULT_PASSWORD=pgadmin_secret_change_me
PGADMIN_LISTEN_PORT=5050

# ---- Ollama ----
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODELS=llama3

# ---- AI Service ----
AI_SERVICE_HOST=ai-service
AI_SERVICE_PORT=8000
AI_API_KEY=ai_api_key_change_me_in_production
AI_DEFAULT_MODEL_CHAT=llama3
AI_DEFAULT_MODEL_SUMMARY=llama3
AI_DEFAULT_MODEL_QUIZ=llama3
AI_RATE_LIMIT_CHAT=20
AI_RATE_LIMIT_SUMMARY=10
AI_RATE_LIMIT_QUIZ=5
AI_MAX_INPUT_LENGTH=2000
AI_CHAT_HISTORY_LIMIT=5
AI_LOG_LEVEL=INFO
