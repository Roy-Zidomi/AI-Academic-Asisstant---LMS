{{!
    @template theme_teluai/landing_hero
}}
<section id="home" class="telu-hero">
    <div class="telu-container telu-hero__inner">
        <div class="telu-hero__content">
            <span class="telu-hero__badge">AI-Powered Learning Platform</span>
            <h1>Smart Learning,<br>Powered by AI</h1>
            <p>
                Platform pembelajaran cerdas berbasis Moodle dan Artificial Intelligence untuk membantu
                mahasiswa, dosen, dan admin mengelola proses belajar mengajar secara lebih personal,
                efektif, dan interaktif.
            </p>
            <div class="telu-hero__actions">
                <a class="telu-btn telu-btn--primary" href="{{{ loginurl }}}">Login to LMS</a>
                <a class="telu-btn telu-btn--secondary" href="#features">Explore Features</a>
            </div>
            <ul class="telu-trust-list" aria-label="Platform trust points">
                <li>Moodle-based LMS</li>
                <li>Local AI with Ollama</li>
                <li>Role-Based Learning Experience</li>
            </ul>
        </div>

        <div class="telu-hero__visual" aria-label="AI learning dashboard preview">
            <div class="telu-dashboard-mock">
                <div class="telu-dashboard-mock__top">
                    <span></span><strong>Personal Dashboard</strong><em>Role-based</em>
                </div>
                <article class="telu-mock-card telu-mock-card--chat">
                    <strong>AI Assistant</strong>
                    <p>Explain this topic in simple academic language.</p>
                </article>
                <article class="telu-mock-card">
                    <strong>Summary Card</strong>
                    <span>Key points generated from learning material.</span>
                </article>
                <article class="telu-mock-card">
                    <strong>Quiz Generator</strong>
                    <span>MCQ, essay, and true/false draft ready for review.</span>
                </article>
            </div>
        </div>
    </div>
</section>
