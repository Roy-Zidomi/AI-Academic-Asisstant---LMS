{{!
    @template theme_teluai/personalized_experience
}}
<section id="experience" class="telu-section telu-section--soft">
    <div class="telu-container">
        <div class="telu-section-head">
            <span class="telu-eyebrow">Personalized learning</span>
            <h2>Personalized Learning Experience</h2>
            <p>Setelah login, setiap user akan melihat dashboard, course, materi, assignment, quiz, dan fitur AI sesuai role, permission, dan enrollment masing-masing.</p>
        </div>
        <div class="telu-experience-grid">
            <article class="telu-experience-card"><h3>Student Experience</h3><ul><li>My Courses sesuai enrollment</li><li>Learning materials</li><li>Assignments and submissions</li><li>Quiz attempts and results</li><li>Grades and progress</li><li>AI Academic Assistant</li><li>Material summaries</li></ul></article>
            <article class="telu-experience-card"><h3>Lecturer Experience</h3><ul><li>Managed courses</li><li>Upload learning materials</li><li>Assignment management</li><li>Quiz management</li><li>AI Quiz Generator</li><li>AI Material Summarizer</li><li>Submission review and grading</li></ul></article>
            <article class="telu-experience-card"><h3>Admin Experience</h3><ul><li>User management</li><li>Role and permission management</li><li>Course management</li><li>System configuration</li><li>AI usage logs</li><li>Audit monitoring</li><li>Platform governance</li></ul></article>
        </div>
        <div class="telu-centered-action"><a class="telu-btn telu-btn--primary" href="{{{ loginurl }}}">Login to view your dashboard</a></div>
    </div>
</section>
