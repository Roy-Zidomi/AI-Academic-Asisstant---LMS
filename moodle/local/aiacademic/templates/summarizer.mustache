<div class="local_aiacademic_summarizer_container">
    <div class="card p-4 mb-4 select_material_card">
        <h3>{{summary_title}}</h3>
        <p class="text-muted">Select a learning material from this course to view or generate an AI summary.</p>
        
        <form id="summarizer-form" class="form-inline mt-3">
            <input type="hidden" name="sesskey" value="{{sesskey}}">
            
            <div class="form-group mr-3 w-50">
                <select id="material-select" class="form-control w-100" required>
                    <option value="" disabled {{^cmid}}selected{{/cmid}}>-- Select Learning Material --</option>
                    {{#materials}}
                        <option value="{{cmid}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                    {{/materials}}
                </select>
            </div>
            
            <button type="submit" id="btn-summarize" class="btn btn-primary mr-2" {{^has_materials}}disabled{{/has_materials}}>
                <i class="fa fa-magic"></i> {{labels.generate}}
            </button>
            
            <button type="button" id="btn-force-summarize" class="btn btn-outline-secondary" style="display: none;">
                <i class="fa fa-refresh"></i> {{labels.regenerate}}
            </button>
        </form>
        
        {{^has_materials}}
            <div class="alert alert-warning mt-3">
                No file resources found in this course. Please upload PDF, PPTX, or TXT materials first.
            </div>
        {{/has_materials}}
    </div>

    <!-- Loading Screen -->
    <div id="summarizer-loading" class="text-center py-5 card" style="display: none;">
        <div class="spinner_container mb-3">
            <i class="fa fa-spinner fa-spin fa-3x text-primary"></i>
        </div>
        <h4>{{labels.loading}}</h4>
        <p class="text-muted">This process extracts files locally and triggers model inference. It may take up to 60 seconds.</p>
    </div>

    <!-- Results Display -->
    <div id="summarizer-results" class="card p-4 summary_results_container" style="display: none;">
        <div class="summary_header d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
            <h2 id="summary-material-title">Material Summary</h2>
            <span id="summary-meta-badge" class="badge badge-info">model: llama3</span>
        </div>

        <!-- Navigation Tabs -->
        <ul class="nav nav-tabs mb-4" id="summaryTabs" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" id="executive-tab" data-toggle="tab" href="#executive" role="tab">{{labels.executive}}</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="keypoints-tab" data-toggle="tab" href="#keypoints" role="tab">{{labels.key_points}}</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="concepts-tab" data-toggle="tab" href="#concepts" role="tab">{{labels.concepts}}</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="glossary-tab" data-toggle="tab" href="#glossary" role="tab">{{labels.glossary}}</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="studyguide-tab" data-toggle="tab" href="#studyguide" role="tab">{{labels.study_guide}}</a>
            </li>
        </ul>

        <!-- Tab Contents -->
        <div class="tab-content" id="summaryTabContent">
            <!-- Executive Summary -->
            <div class="tab-pane fade show active" id="executive" role="tabpanel">
                <div id="content-executive" class="summary_paragraph"></div>
            </div>

            <!-- Key Points -->
            <div class="tab-pane fade" id="keypoints" role="tabpanel">
                <ul id="content-keypoints" class="list-group list-group-flush summary_list">
                    <!-- Key points injected -->
                </ul>
            </div>

            <!-- Concepts -->
            <div class="tab-pane fade" id="concepts" role="tabpanel">
                <div id="content-concepts" class="row concepts_grid">
                    <!-- Concept cards injected -->
                </div>
            </div>

            <!-- Glossary -->
            <div class="tab-pane fade" id="glossary" role="tabpanel">
                <table class="table table-striped table-hover mt-2">
                    <thead>
                        <tr>
                            <th style="width: 25%;">Term</th>
                            <th>Definition</th>
                        </tr>
                    </thead>
                    <tbody id="content-glossary">
                        <!-- Glossary entries injected -->
                    </tbody>
                </table>
            </div>

            <!-- Study Guide -->
            <div class="tab-pane fade" id="studyguide" role="tabpanel">
                <div id="content-studyguide" class="summary_paragraph"></div>
            </div>
        </div>
    </div>
</div>
